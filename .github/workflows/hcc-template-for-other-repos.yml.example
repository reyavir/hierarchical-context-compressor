# Copy this file to YOUR repository as:
#   .github/workflows/hcc-context.yml
# (remove .example from the filename)
#
# Prerequisites:
#   1. Repo secret: Settings → Secrets → OPENAI_API_KEY
#   2. Grant workflow write access: Settings → Actions → General →
#      "Workflow permissions" → Read and write (needed to push commits)
#
# Adjust branch name (main) or triggers (pull_request, schedule, etc.) as needed.

name: Update AI context (agents.md / AGENTS.md)

on:
  push:
    branches:
      - main
  workflow_dispatch: {} # optional: run manually from Actions tab

jobs:
  hcc:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install hcc
        run: pip install "git+https://github.com/reyavir/hierarchical-context-compressor.git"

      - name: Generate context
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
        run: hcc --root .

      - name: Commit and push if changed
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add agents.md 2>/dev/null || true
          [ -f llms.txt ] && git add llms.txt
          git add ':(glob)**/AGENTS.md' 2>/dev/null || true
          if git diff --cached --quiet; then
            echo "No context file changes."
            exit 0
          fi
          git commit -m "chore: update AI context maps (hcc)"
          git push
